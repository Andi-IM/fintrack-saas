GEMINI_API_KEY=
GROQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Modal docTR OCR Service Configuration
# OCR_SERVICE_URL must point to the deployed Modal endpoint, for example:
# https://your-workspace--doctr-web-api-ocr-api.modal.run
OCR_SERVICE_URL=""
OCR_API_KEY=""

# Bypass local authentication (set to true ONLY for testing/mocking, defaults to false)
BYPASS_AUTH=false

