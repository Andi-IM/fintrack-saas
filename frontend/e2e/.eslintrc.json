{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true,
    "mocha": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:wdio/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "wdio"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  }
}
